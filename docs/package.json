{
  "name": "pocketci-docs",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "VitePress docs for PocketCI",
  "scripts": {
    "dev": "vitepress dev",
    "build": "vitepress build && npm run build:embed",
    "build:embed": "mkdir -p ../server/docs/site && rsync -a --delete .vitepress/dist/ ../server/docs/site/ && mkdir -p ../site/docs && rsync -a --delete .vitepress/dist/ ../site/docs/",
    "preview": "vitepress preview"
  },
  "devDependencies": {
    "vitepress": "^1.6.4"
  }
}
