# Cloudflare Pages — cache rules
# index.html: no cache (content changes on every deploy)
/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

# Docs immutable assets carry content hashes — cache forever
/docs/assets/*
  Cache-Control: public, max-age=31536000, immutable
